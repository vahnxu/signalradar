# SignalRadar environment template
# Copy to .env and fill values as needed. All variables are optional.

# --- Notion integration (only for watchlist-refresh mode) ---
NOTION_API_KEY=your_notion_integration_secret
NOTION_API_VERSION=2022-06-28
NOTION_PARENT_PAGE_ID=your_parent_page_id

# --- Optional overrides ---
# SIGNALRADAR_CONFIG=/path/to/signalradar_config.json
# SIGNALRADAR_WORKSPACE_ROOT=/path/to/workspace
