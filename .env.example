# SignalRadar environment template
# Copy to .env and fill values for your deployment.
# NOTE: SIGNALRADAR_* values below are reference defaults for manual/scheduled runs.
# Main runtime prefers CLI args and/or --config JSON.

# Notion integration (required for watchlist-refresh with Notion sync)
NOTION_API_KEY=your_notion_integration_secret
NOTION_API_VERSION=2022-06-28
NOTION_PARENT_PAGE_ID=your_parent_page_id

# Optional user data directory override (default: ~/.signalradar)
SIGNALRADAR_DATA_DIR=/tmp/signalradar

# Optional config file path override (default: ~/.signalradar/config/signalradar_config.json)
SIGNALRADAR_CONFIG=/tmp/signalradar/config/signalradar_config.json

# Optional runtime defaults
SIGNALRADAR_USER_TIMEZONE=Asia/Shanghai
SIGNALRADAR_THRESHOLD_ABS_PP=5
SIGNALRADAR_THRESHOLD_REL_PCT=5
SIGNALRADAR_DEDUP_WINDOW_MINUTES=0
